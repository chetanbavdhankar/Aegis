# ─────────────────────────────────────────────────────────────────────────────
# AEGIS — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Mistral AI ────────────────────────────────────────────────────────────────
# Get from https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# Model to use for structured extraction and translation (default: mistral-large-latest)
MISTRAL_MODEL=mistral-large-latest

# Model to use for the agentic verification agent (default: mistral-large-latest)
MISTRAL_AGENT_MODEL=mistral-large-latest

# ── ElevenLabs TTS (optional) ─────────────────────────────────────────────────
# Get from https://elevenlabs.io — leave blank to use text-only mode
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID to use (default: "George" multilingual voice)
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# TTS model (default: eleven_multilingual_v2)
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Flask Server ──────────────────────────────────────────────────────────────
# Host and port for the dashboard web server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Set to true only during local development — never in production
FLASK_DEBUG=false

# ── Responder Settings ────────────────────────────────────────────────────────
# Language of the responder dashboard (outbound messages are translated TO this language)
RESPONDER_LANGUAGE=Italian
